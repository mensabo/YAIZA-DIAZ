rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'mensabo78@gmail.com';
    }

    // Adjuntos del formulario de contacto: cualquiera puede subir (es un
    // formulario público), tamaño limitado a 10MB, sin sobrescritura de
    // archivos existentes ni borrado público.
    match /contact-attachments/{fileName} {
      allow read: if true;
      allow create: if request.resource.size < 10 * 1024 * 1024;
      allow update, delete: if isAdmin();
    }

    // Resto de imágenes/vídeos del sitio: lectura pública, escritura solo
    // admin, limitada a 20MB por archivo.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 20 * 1024 * 1024;
    }
  }
}
