# Configuracion para IONOS (Apache) que replica lo que hace firebase.json
# en Firebase Hosting: URLs limpias sin .html, cabeceras de cache y de
# seguridad, redireccion a HTTPS y a www, y pagina 404 personalizada.
#
# panel-yz28da.html/.js llevan meta robots noindex en el propio HTML y no
# se listan en robots.txt (para no publicar esa ruta); ademas van
# protegidos con contraseña de servidor (.htpasswd-panel) mas abajo,
# independiente del login de Firebase.

# Bloquea el acceso directo a cualquier archivo .ht* (.htaccess, .htpasswd-panel)
<Files ~ "^\.ht">
Require all denied
</Files>

# Contraseña de servidor para el panel de admin, ademas del login de Firebase
<Files "panel-yz28da.html">
AuthType Basic
AuthName "Acceso restringido"
AuthUserFile "/homepages/28/d4299186613/htdocs/YAIZADIAZ/.htpasswd-panel"
Require valid-user
</Files>

<IfModule mod_rewrite.c>
RewriteEngine On

# 1. Forzar HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. Forzar www (coincide con las URLs canonicas/sitemap del sitio)
RewriteCond %{HTTP_HOST} ^yaizadiaz\.com$ [NC]
RewriteRule ^(.*)$ https://www.yaizadiaz.com/$1 [L,R=301]

# 3. Si alguien pide /pagina.html, redirigir de forma permanente a /pagina
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# 4. Servir pagina.html cuando se pide /pagina (sin redirigir, URL limpia)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.*)$ $1.html [L]
</IfModule>

# Pagina 404 personalizada
ErrorDocument 404 /404.html

# Cabeceras de cache (mismos tiempos que firebase.json)
<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType image/jpeg "access plus 7 days"
ExpiresByType image/png "access plus 7 days"
ExpiresByType image/gif "access plus 7 days"
ExpiresByType image/webp "access plus 7 days"
ExpiresByType image/svg+xml "access plus 7 days"
ExpiresByType image/x-icon "access plus 7 days"
ExpiresByType video/mp4 "access plus 7 days"
ExpiresByType audio/mpeg "access plus 7 days"
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType font/woff "access plus 1 month"
ExpiresByType font/woff2 "access plus 1 month"
ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
<FilesMatch "\.(css|js)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico|mp4|mp3)$">
Header set Cache-Control "public, max-age=604800"
</FilesMatch>
<FilesMatch "\.(woff|woff2)$">
Header set Cache-Control "public, max-age=2592000"
</FilesMatch>
<FilesMatch "\.html$">
Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set Referrer-Policy "strict-origin-when-cross-origin"
Header set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=()"
</IfModule>
